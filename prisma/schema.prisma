generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Tenancy ─────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  tenant_admin
  analyst
  viewer
}

enum TenantStatus {
  trial
  active
  paused
  deprovisioned
}

enum TenantPlan {
  demo
  trial
  starter_ir   // 1–50 seats — core IR-focused stack
  smb          // 50–500 seats — full platform
  enterprise   // 500+ seats — unlimited + priority support
}

model Tenant {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  status        TenantStatus @default(trial)
  plan          TenantPlan   @default(trial)
  /** Maximum active users this tenant is provisioned for. Null = unlimited (enterprise). */
  seatLimit     Int?
  isDemoTenant  Boolean      @default(false)
  trialEndsAt   DateTime?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  notes         String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  organization  Organization?
  users         User[]
  state         TenantState?
  assessments   Assessment[]
  incidents     Incident[]
  tickets       Ticket[]
  tasks         Task[]
  stakeholders  Stakeholder[]
  keySystems    KeySystem[]
  vendors       Vendor[]
  policies      Policy[]
  tabletops     Tabletop[]
  forensicLogs  ForensicLog[]
  lessons       Lesson[]
  notifications IncidentNotification[]
  customPlaybooks CustomPlaybook[]
  accessLogs    AccessActivityLog[]
  provisioningCredentials ProvisioningCredential[]

  @@index([status])
  @@index([isDemoTenant])
}

model User {
  id        String   @id // Mirrors Supabase auth.users.id (UUID)
  email     String   @unique
  fullName  String?
  /** Company / organization the member represents — useful for vendors, MSPs, vCISO partners on the team. */
  company   String?
  /** Free-form job title for display in the team table. */
  jobTitle  String?
  role      UserRole @default(viewer)
  // Fine-grained in-tenant role used by the in-app RBAC matrix (rbac.ts).
  // Distinct from the prisma `role` enum which is the auth-tier (super_admin / tenant_admin / analyst / viewer).
  appRole   String   @default("viewer") // admin | manager | analyst | viewer
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  invitedBy String?
  invitedAt DateTime?
  lastSeenAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([role])
}

// Per-tenant Zustand snapshot — the everything-blob.
// Auto-saved on change (debounced) by the running app, hydrated on load.
model TenantState {
  tenantId  String   @id
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  data      Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ─── Per-tenant data ─────────────────────────────────────────────────

model Organization {
  id           String   @id @default(cuid())
  name         String
  industry     String?
  size         String?
  website      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  techStack    Json?
  compliance   String[]
  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Assessment {
  id        String   @id // Stable id supplied by the app (Date.now().toString())
  framework String   @default("NIST CSF 2.0")
  orgName   String   @default("")
  date      String   @default("") // Display-formatted date string from the app
  score     Int
  answers   Json
  fnScores  Json     // Per-CSF-function scores (was grpScores)
  catScores Json?
  warnings  Json
  recs      Json
  hitlist   Json?    // { shortTerm: [...], achievable: [...], aspirational: [...] }
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

model Incident {
  id             String   @id // App-supplied incidentId (e.g. INC-DEMO-001)
  title          String
  severity       String
  status         String   // "Active" | "Closed"
  declaredAt     String   // Display-formatted date string from the app
  closedAt       String?
  masterTicketId Int?
  data           Json?    // Full incident record (timeline, findings, IOCs, etc.) when set
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, declaredAt])
}

model Ticket {
  id                     String   @id // Stable id supplied by the app
  title                  String
  severity               String
  status                 String   @default("Open")
  phase                  String?
  assignee               String?
  details                String?  @db.Text
  actions                Json
  created                String?  // Display-formatted date string from the app
  // Hierarchy
  parentId               String?
  childIds               Json?    // string[] of child ticket ids
  // Incident linkage
  ticketType             String?  // "master" | "child" | "standalone" | "security-event"
  incidentId             String?
  incidentTitle          String?
  // Threat intel linkage
  threatIntelId          String?
  threatIntelTitle       String?
  applicability          String?  // "applicable" | "not-applicable" | "pending"
  verifiedExploit        Boolean?
  // Misc
  playbookId             String?
  subtaskCount           Int?
  tenantId               String
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, ticketType])
}

model Task {
  id          String   @id // Stable id supplied by the app
  title       String
  priority    String
  status      String   @default("Backlog")
  assignee    String?
  source      String?
  updates     Json
  created     String?  // Display-formatted date string from the app
  irPhase     String?
  incidentId  String?
  ticketId    String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

model Stakeholder {
  id               String   @id // Stable id supplied by the app
  groupKey         String
  firstName        String
  lastName         String
  title            String?
  responsibilities String?  @db.Text
  email            String?
  cell             String?
  // Invite tracking: when an admin promotes a stakeholder to a Sentry user, we link the resulting User here
  // and capture which fine-grained app role was assigned at invite time.
  userId           String?
  invitedAt        DateTime?
  inviteStatus     String?  // "invited" | "accepted" — null when never invited
  appRole          String?  // admin | manager | analyst | viewer — recommendation chosen at invite
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([tenantId, groupKey])
  @@index([tenantId, userId])
}

model KeySystem {
  id          String   @id // Stable id supplied by the app
  systemName  String
  category    String
  criticality String
  owner       String?
  ownerEmail  String?
  ownerCell   String?
  notes       String?  @db.Text
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

model Vendor {
  id            String   @id // Stable id supplied by the app
  category      String
  vendorName    String
  productName   String?
  accountId     String?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  supportPortal String?
  supportTier   String?
  slaResponse   String?
  isPrimary     Boolean  @default(false)
  notes         String?  @db.Text
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([tenantId, category])
}

model Policy {
  // Each row represents one policy instance (one per template per tenant).
  // Versioned content lives in PolicyVersion; the IDs below point at the
  // currently published version and the active editable draft.
  id                 String   @id // = ${tenantId}:${templateId}
  templateId         String
  title              String?
  publishedVersionId String?  // null until first publication
  draftVersionId     String?  // null when no edit is in progress
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions           PolicyVersion[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId, templateId])
  @@index([tenantId])
}

// Time-limited storage of provisioning credentials (one-time magic links,
// initial passwords) generated for tenant users. Super-admins can re-view
// these from the tenant detail page until they expire or are explicitly
// invalidated — fixes the "credentials vanish on page reload" problem.
//
// SECURITY: stored at-rest in the application DB. The window is
// intentionally short (7 days default). On view, viewedAt is recorded; on
// successful first sign-in we invalidate the row. Never log the value.
model ProvisioningCredential {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /** The user this credential authenticates. Null for invite-link-only flows. */
  userId        String?
  userEmail     String
  /** "magiclink" or "password" — drives the UI presentation. */
  kind          String
  /** The secret itself — magic-link URL or temporary password. */
  value         String   @db.Text
  /** When auto-expires. Default = now + 7 days at insert time. */
  expiresAt     DateTime
  /** Who last revealed this credential. Captured for audit. */
  viewedByUserId String?
  viewedByName  String?
  viewedAt      DateTime?
  /** Marks the credential as no longer valid (consumed, manually rotated, etc.) */
  invalidatedAt DateTime?
  /** Reason for generation: "tenant_created" | "manual_resend" | "user_added" */
  source        String
  createdByUserId String
  createdByName String?
  createdAt     DateTime @default(now())

  @@index([tenantId, expiresAt])
  @@index([tenantId, userId])
}

// Per-user acknowledgment that they've read a specific published version.
// (tenantId, policyVersionId, userId) is unique — re-acknowledging the same
// version is a no-op. When a new version publishes, prior acknowledgments
// remain on the old version (audit record) and the new version starts with
// zero acks.
model PolicyAcknowledgment {
  id              String   @id @default(cuid())
  tenantId        String
  policyId        String   // Policy.id ("${tenantId}:${templateId}")
  policyVersionId String
  userId          String
  userName        String?  // snapshot — survives later renames / deletes
  userEmail       String?
  acknowledgedAt  DateTime @default(now())

  @@unique([policyVersionId, userId])
  @@index([tenantId, policyId])
  @@index([tenantId, userId])
}

model PolicyVersion {
  // Append-only version log. Draft = editable. Published = immutable.
  // Submitter implicitly signs off at submission; an explicitly-named
  // approver must subsequently sign off before publication.
  id                  String   @id
  policyId            String
  policy              Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  versionNumber       Int      // monotonic per policy: 1, 2, 3...
  content             String   @db.Text  // markdown
  status              String   // "draft" | "in_review" | "published" | "archived"
  changesSummary      String?  // optional changelog note
  // Submission (= first signoff, captured automatically at submit-for-review)
  submitterUserId     String?
  submitterName       String?
  submittedAt         DateTime?
  // Named approver — must be a distinct platform user. Captured at submit time.
  approverUserId      String?
  approverName        String?
  // Approver signoff (= second signoff, captured when the named approver
  // clicks "Sign off").
  approverSignedAt    DateTime?
  // Publication
  publishedAt         DateTime?
  publishedByUserId   String?
  publishedByName     String?
  // Authorship
  createdByUserId     String
  createdByName       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([policyId])
  @@index([policyId, versionNumber])
  @@index([policyId, status])
}

model Tabletop {
  id        String   @id // App-supplied id
  title     String
  status    String   @default("Scheduled")
  date      String   // Display-formatted date string
  rating    Int?
  data      Json     // Full record: scenario, participants, objectives, findings, lessonsLearned, actionItems, feedback, etc.
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, date])
}

model ForensicLog {
  id             String   @id // App-supplied id
  title          String
  classification String
  incidentId     String?
  data           Json     // Full record: chainOfCustody, accessList, files, encrypted, locked, etc.
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([tenantId, incidentId])
  @@index([tenantId, classification])
}

model Lesson {
  id        String   @id // App-supplied id
  text      String   @db.Text
  src       String?  // Source/origin (e.g. "Tabletop AAR", "Incident IR")
  date      String?  // Display date string
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

// Audit trail of every access-related event in a tenant: sign-ins, invites,
// role / profile changes, deletions, impersonation. Read by the Access
// Control module's Activity Log tab; never mutated, only appended.
model AccessActivityLog {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /** The user performing the action. Null for system-initiated events. */
  actorUserId     String?
  actorName       String?
  actorEmail      String?
  /** Semantic action identifier — see ACCESS_ACTIONS in src/data/access-actions.ts. */
  action          String
  /** When the action targeted another user, that user's identifying info — snapshotted so the log survives later deletes. */
  targetUserId    String?
  targetEmail     String?
  targetName      String?
  /** Optional structured detail (e.g. {from: "viewer", to: "manager"}, {tenantId: "X"} for impersonation). */
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([tenantId, actorUserId])
}

// Custom playbooks — tenant-specific playbooks created from scratch or by
// cloning a preset. Presets remain immutable in src/data/playbooks.ts;
// edits to a preset always produce a new CustomPlaybook row.
model CustomPlaybook {
  id                String   @id // app-supplied; format "cpb_<tenant>_<n>"
  sourcePlaybookId  String?  // preset id if this was cloned from one
  name              String
  cat               String
  sev               String   // "Low" | "Medium" | "High" | "Critical"
  icon              String   @default("📋")
  desc              String   @db.Text
  iocs              String[]
  contain           String[]
  erad              String[]
  recover           String[]
  mitre             String[]
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, sourcePlaybookId])
}

// Threat intelligence is global (cross-tenant) but optionally pinned to a tenant
model ThreatIntel {
  id                  String   @id @default(cuid())
  feedSource          String
  feedCategory        String
  industryTag         String?

  title               String
  description         String   @db.Text
  link                String
  publishedAt         DateTime
  fetchedAt           DateTime @default(now())

  cveId               String?
  cvssScore           Float?
  cvssVector          String?
  cweId               String?
  affectedVendors     String[]
  affectedProducts    String[]

  severityRank        String
  impactScore         Int
  likelihoodScore     Int
  riskScore           Int
  isZeroDay           Boolean  @default(false)
  isActivelyExploited Boolean  @default(false)

  tags                String[]
  mitreAttackIds      String[]
  recommendations     String?  @db.Text
  executiveSummary    String?  @db.Text

  expiresAt           DateTime

  @@index([publishedAt])
  @@index([severityRank])
  @@index([feedCategory])
  @@index([industryTag])
  @@index([expiresAt])
}

model IncidentNotification {
  id                  String    @id @default(cuid())
  incidentId          String

  type                String
  tier                Int
  groupKey            String
  groupLabel          String

  recipients          Json
  recipientCount      Int

  subject             String
  body                String    @db.Text
  classification      String
  channel             String    @default("email")

  deltaFromId         String?
  deltaSummary        String?   @db.Text
  version             Int       @default(1)

  incidentSnapshot    Json

  correctionOfId      String?
  correctionReason    String?
  retracted           Boolean   @default(false)
  retractedBy         String?
  retractedAt         DateTime?
  retractedReason     String?

  generatedBy         String
  generatedByEmail    String?
  generatedAt         DateTime  @default(now())
  approvalRequired    Boolean   @default(false)
  approvedBy          String?
  approvedByEmail     String?
  approvedAt          DateTime?
  approvalStatus      String?
  rejectionReason     String?
  sentBy              String
  sentByEmail         String?
  sentAt              DateTime  @default(now())
  sendMethod          String

  acknowledged        Boolean   @default(false)
  acknowledgedBy      String?
  acknowledgedByEmail String?
  acknowledgedAt      DateTime?

  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, incidentId, groupKey])
  @@index([tenantId, incidentId, sentAt])
  @@index([tenantId, incidentId, version])
}

